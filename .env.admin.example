# Admin runtime
APP_ENV=production
APP_DEBUG=false
ADMIN_ENABLED=true
ADMIN_ONLY=true
ADMIN_PATH=
TELEGRAM_DEV_AUTH_ENABLED=false
ADMIN_APP_HEALTH_HOST=app
ADMIN_APP_HEALTH_PORT=9000
ADMIN_SESSION_LIFETIME_SECONDS=1800
ADMIN_LOGIN_ATTEMPT_LIMIT=5
ADMIN_LOGIN_ATTEMPT_WINDOW_SECONDS=900

# Admin database user. Keep this separate from the main app DB user.
DB_HOST=foodtracker-db
DB_NAME=foodtracker_db
DB_USER=foodtracker_admin
DB_PASS=

# Keep these in sync with DB_USER/DB_PASS for docker/db/init/01-create-admin-user.sh.
ADMIN_DB_USER=${DB_USER}
ADMIN_DB_PASS=${DB_PASS}
