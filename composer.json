{
    "name": "eternalslumber/foodtracker",
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "db:bootstrap": "php scripts/bootstrap_database.php",
        "migrate": "php scripts/migrate.php",
        "cleanup:uploads": "php scripts/cleanup_uploads.php",
        "notifications:dispatch": "php scripts/dispatch_notifications.php",
        "build:frontend": "php scripts/build_frontend.php",
        "test:frontend": "node --test tests/frontend/*.test.js"
    },
    "require": {
        "php": "^8.5",
        "vlucas/phpdotenv": "^5.6",
        "slim/slim": "^4.14",
        "slim/psr7": "^1.7",
        "php-di/php-di": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^13"
    }

}
