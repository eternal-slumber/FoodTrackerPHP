# App
APP_ENV=production
APP_DEBUG=false

# Database
DB_HOST=
DB_NAME=
DB_USER=
DB_PASS=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_AUTH_MAX_AGE_SECONDS=86400
TELEGRAM_WEBHOOK_SECRET_TOKEN=
TELEGRAM_MINI_APP_URL=

# Same sign convention as JS Date.getTimezoneOffset().
# Moscow is -180, UTC is 0.
TELEGRAM_BOT_DEFAULT_TZ_OFFSET_MINUTES=0

# Must stay false outside local development
TELEGRAM_DEV_AUTH_ENABLED=false

# AI provider: openrouter|lmstudio
AI_PROVIDER=openrouter
AI_BASE_URL=https://openrouter.ai/api/v1
AI_API_KEY=
AI_MODEL=nvidia/nemotron-nano-12b-v2-vl:free

# Upload cleanup
UPLOAD_ORPHAN_TTL_SECONDS=86400

# Local-only examples:
# APP_ENV=local
# TELEGRAM_DEV_AUTH_ENABLED=true
# TELEGRAM_DEV_USER_ID=100001
# TELEGRAM_DEV_USERNAME=dev_user
# AI_PROVIDER=lmstudio
# AI_BASE_URL=http://host.docker.internal:1234/v1
# AI_API_KEY=lm-studio
# AI_MODEL=google/gemma-4-e4b
